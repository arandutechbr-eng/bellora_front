# Copie para .env apenas no seu PC (não commitar .env)
# Produção: configure no painel da Vercel → VITE_API_URL

# Local
VITE_API_URL=http://localhost:8000/api/v1

# Produção (Vercel) — com ou sem /api/v1 no final, o app normaliza
# VITE_API_URL=https://zola-back.onrender.com
# ou: https://zola-back.onrender.com/api/v1
